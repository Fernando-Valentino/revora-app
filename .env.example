APP_NAME="REVORA"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001
APP_LOCALE=id
APP_TIMEZONE=Asia/Jakarta

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# 1. Database Configuration (Connecting to mysql_db docker container)
DB_CONNECTION=mysql
DB_HOST=mysql_db
DB_PORT=3306
DB_DATABASE=svr_parkir
DB_USERNAME=svr_user
DB_PASSWORD=userpassword

# 2. FastAPI Backend Connection Configuration (Connecting to python_api docker container)
FASTAPI_URL=http://python_api:8000
PYTHON_ML_API_URL=http://python_api:8000
FASTAPI_KEY=default-fallback-key
JWT_SECRET=rahasia-jwt-secret-key-123

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=360
